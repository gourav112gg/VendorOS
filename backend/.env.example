# Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vendoros?retryWrites=true&w=majority

# JWT secret — use a long random string in production
JWT_SECRET=your_jwt_secret_key_here

# Python FastAPI ML sidecar URL (default: http://127.0.0.1:8000)
ML_SERVICE_URL=http://127.0.0.1:8000

# Gemini API Key for AI Risk Explanation
GEMINI_API_KEY=your_gemini_api_key_here

# Super Admin Credentials (One-time seed script & 3-factor authentication)
ADMIN_EMAIL=admin@vendoros.com
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_PASSPHRASE=your_secure_static_passphrase
